# Variables de entorno del servidor TortasBO
# Copiá este archivo como .env y completá los valores

# Puerto del servidor (por defecto 3001)
PORT=3001

# API Key de Anthropic Claude (REQUERIDA para la función de análisis IA)
# Obtenela en: https://console.anthropic.com/
CLAUDE_API_KEY=tu_api_key_aqui

# URL del frontend en producción (para restringir CORS)
# En desarrollo no es necesario (acepta cualquier origen)
# FRONTEND_URL=https://tu-dominio.com

# CORS: orígenes permitidos para peticiones al API (separados por coma)
# Dejar vacío o no definir para permitir todos los orígenes (modo desarrollo)
# Ejemplo para producción: CORS_ORIGIN=http://192.168.1.10:5173
CORS_ORIGIN=
